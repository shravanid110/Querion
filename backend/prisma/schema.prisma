// ============================================================
// Prisma Schema — Querion AI Database Assistant
// Database: Supabase PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// EXISTING MODEL — Preserved from previous schema
// ============================================================

model Connection {
  id        String   @id @default(uuid())
  name      String?
  host      String
  port      Int      @default(3306)
  database  String
  username  String
  password  String   // Encrypted
  createdAt DateTime @default(now())

  @@map("connections")
}

// ============================================================
// NEW MODELS — AI Database Assistant System
// ============================================================

/// Application users with role-based access
model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("user") // "user" | "admin" | "viewer"
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  chatSessions ChatSession[]
  prompts      Prompt[]

  @@index([email])
  @@index([role])
  @@map("users")
}

/// Groups a set of messages into one logical conversation
model ChatSession {
  sessionId String    @id @default(uuid()) @map("session_id")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

/// Individual messages exchanged within a chat session
model ChatMessage {
  messageId  String    @id @default(uuid()) @map("message_id")
  sessionId  String    @map("session_id")
  userMessage String   @map("user_message") @db.Text
  aiResponse  Json     @map("ai_response")  // JSON support for structured AI responses
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

/// Natural language prompts submitted by users
model Prompt {
  promptId   String    @id @default(uuid()) @map("prompt_id")
  userId     String    @map("user_id")
  promptText String    @map("prompt_text") @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedQueries GeneratedQuery[]

  @@index([userId])
  @@index([createdAt])
  @@map("prompts")
}

/// SQL queries generated from natural language prompts
model GeneratedQuery {
  queryId       String    @id @default(uuid()) @map("query_id")
  promptId      String    @map("prompt_id")
  generatedSql  String    @map("generated_sql") @db.Text
  executionTime Float?    @map("execution_time") // milliseconds
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  prompt    Prompt     @relation(fields: [promptId], references: [promptId], onDelete: Cascade)
  queryLogs QueryLog[]
  charts    Chart[]

  @@index([promptId])
  @@index([createdAt])
  @@map("generated_queries")
}

/// Execution audit log for every generated SQL query
model QueryLog {
  logId        String    @id @default(uuid()) @map("log_id")
  queryId      String    @map("query_id")
  status       String    // "success" | "error" | "timeout" | "pending"
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  query GeneratedQuery @relation(fields: [queryId], references: [queryId], onDelete: Cascade)

  @@index([queryId])
  @@index([status])
  @@index([createdAt])
  @@map("query_logs")
}

/// Charts and visualizations produced from query results
model Chart {
  chartId   String   @id @default(uuid()) @map("chart_id")
  queryId   String   @map("query_id")
  chartType String   @map("chart_type") // "bar" | "line" | "pie" | "scatter" | "table" …
  chartData Json     @map("chart_data") // Full chart config / data as JSON

  // Relations
  query GeneratedQuery @relation(fields: [queryId], references: [queryId], onDelete: Cascade)

  @@index([queryId])
  @@index([chartType])
  @@map("charts")
}

/// Platform-level usage and performance metrics
model Analytics {
  analyticsId  String   @id @default(uuid()) @map("analytics_id")
  metricName   String   @map("metric_name")
  metricValue  Float    @map("metric_value")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([metricName])
  @@index([createdAt])
  @@map("analytics")
}
